rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || (
            request.auth.token.email is string
            && request.auth.token.email == "admin@mdrrmo.com"
          )
        );
    }

    function isApprovedResident(uid) {
      return exists(/databases/$(database)/documents/residents/$(uid))
        && (
          get(/databases/$(database)/documents/residents/$(uid)).data.verified == true
          || get(/databases/$(database)/documents/residents/$(uid)).data.verificationStatus == "approved"
        );
    }

    match /admins/{uid} {
      allow create: if isOwner(uid)
        && request.auth.token.email is string
        && request.auth.token.email in [
          "admin@mdrrmo.com"
        ]
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == "admin";

      allow read: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    // Resident account profiles created during sign-up.
    match /residents/{uid} {
      allow create: if (
          isOwner(uid)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == "resident"
          && request.resource.data.email is string
          && request.resource.data.fullName is string
          && request.resource.data.phone is string
          && request.resource.data.address is string
          && request.resource.data.barangay is string
          && request.resource.data.city is string
          && request.resource.data.validIdUrl is string
          && request.resource.data.residencyProofUrl is string
          && request.resource.data.idType is string
          && request.resource.data.idNumber is string
          && request.resource.data.verified == false
          && request.resource.data.verificationStatus == "pending"
          && request.resource.data.verifiedAt == null
          && request.resource.data.rejectionReason == null
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp
        ) || (
          isAdmin()
          && request.resource.data.uid == uid
          && request.resource.data.role == "resident"
          && request.resource.data.email is string
          && request.resource.data.fullName is string
          && request.resource.data.phone is string
          && request.resource.data.address is string
          && request.resource.data.barangay is string
          && request.resource.data.city is string
          && request.resource.data.validIdUrl is string
          && request.resource.data.residencyProofUrl is string
          && request.resource.data.idType is string
          && request.resource.data.idNumber is string
          && request.resource.data.verificationStatus in ["pending", "approved", "rejected"]
          && (
            (request.resource.data.verificationStatus == "approved"
              && request.resource.data.verified == true
              && request.resource.data.rejectionReason == null)
            || (request.resource.data.verificationStatus != "approved"
              && request.resource.data.verified == false)
          )
          && (
            (request.resource.data.verificationStatus == "approved"
              && request.resource.data.verifiedAt is timestamp)
            || (request.resource.data.verificationStatus != "approved"
              && request.resource.data.verifiedAt == null)
          )
          && (
            (request.resource.data.verificationStatus == "rejected"
              && request.resource.data.rejectionReason is string
              && request.resource.data.rejectionReason.size() > 0
              && request.resource.data.rejectionReason.size() <= 500)
            || (request.resource.data.verificationStatus != "rejected"
              && request.resource.data.rejectionReason == null)
          )
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp
        );

      allow read: if isOwner(uid) || isAdmin();
        allow update: if (
          isOwner(uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role == "resident"
          && request.resource.data.email == resource.data.email
          && request.resource.data.verified == resource.data.verified
          && request.resource.data.verificationStatus == resource.data.verificationStatus
          && request.resource.data.verifiedAt == resource.data.verifiedAt
          && request.resource.data.rejectionReason == resource.data.rejectionReason
        ) || (
          isAdmin()
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.fullName is string
          && request.resource.data.phone is string
          && request.resource.data.address is string
          && request.resource.data.barangay is string
          && request.resource.data.city is string
          && request.resource.data.validIdUrl is string
          && request.resource.data.residencyProofUrl is string
          && request.resource.data.idType is string
          && request.resource.data.idNumber is string
          && request.resource.data.verificationStatus in ["pending", "approved", "rejected"]
          && (
            (request.resource.data.verificationStatus == "approved"
              && request.resource.data.verified == true
              && request.resource.data.rejectionReason == null)
            || (request.resource.data.verificationStatus != "approved"
              && request.resource.data.verified == false)
          )
          && (
            (request.resource.data.verificationStatus == "rejected"
              && request.resource.data.rejectionReason is string
              && request.resource.data.rejectionReason.size() > 0
              && request.resource.data.rejectionReason.size() <= 500)
            || (request.resource.data.verificationStatus != "rejected"
              && request.resource.data.rejectionReason == null)
          )
          && (
            (request.resource.data.verificationStatus == "approved"
              && request.resource.data.verifiedAt is timestamp)
            || (request.resource.data.verificationStatus != "approved"
              && request.resource.data.verifiedAt == null)
          )
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt is timestamp
        );
      allow delete: if isAdmin();
    }

    match /responders/{uid} {
      allow create: if isAdmin()
        && request.resource.data.uid == uid
        && request.resource.data.role == "responder"
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.type in ["Police", "Fire", "Medical", "Disaster"]
        && request.resource.data.status in ["Available", "Deployed", "Off-Duty"]
        && request.resource.data.contact is string
        && (request.resource.data.currentIncidentId == null
          || request.resource.data.currentIncidentId is string)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow read: if isAdmin() || isOwner(uid);

      allow update: if (
          isAdmin()
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.name is string
          && request.resource.data.type in ["Police", "Fire", "Medical", "Disaster"]
          && request.resource.data.status in ["Available", "Deployed", "Off-Duty"]
          && request.resource.data.contact is string
          && (request.resource.data.currentIncidentId == null
            || request.resource.data.currentIncidentId is string)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt is timestamp
        ) || (
          isOwner(uid)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "sessionActive",
            "sessionLastSeenAt",
            "liveLocation",
            "liveLocationUpdatedAt",
            "sessionStartedAt",
            "sessionEndedAt",
            "lastLoginAt",
            "status",
            "currentIncidentId",
            "updatedAt"
          ])
          && request.resource.data.updatedAt is timestamp
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["sessionActive"])
            || request.resource.data.sessionActive == null
            || request.resource.data.sessionActive is bool)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["sessionLastSeenAt"])
            || request.resource.data.sessionLastSeenAt == null
            || request.resource.data.sessionLastSeenAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["liveLocationUpdatedAt"])
            || request.resource.data.liveLocationUpdatedAt == null
            || request.resource.data.liveLocationUpdatedAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["sessionStartedAt"])
            || request.resource.data.sessionStartedAt == null
            || request.resource.data.sessionStartedAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["sessionEndedAt"])
            || request.resource.data.sessionEndedAt == null
            || request.resource.data.sessionEndedAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["lastLoginAt"])
            || request.resource.data.lastLoginAt == null
            || request.resource.data.lastLoginAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["status"])
            || request.resource.data.status == null
            || request.resource.data.status in ["Available", "Deployed", "Off-Duty"])
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["currentIncidentId"])
            || request.resource.data.currentIncidentId == null
            || request.resource.data.currentIncidentId is string)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["liveLocation"])
            || request.resource.data.liveLocation == null
            || (
              (
                (request.resource.data.liveLocation.latitude is number
                  && request.resource.data.liveLocation.longitude is number)
                || (request.resource.data.liveLocation.lat is number
                  && request.resource.data.liveLocation.lng is number)
              )
              && (request.resource.data.liveLocation.latitude == null
                || request.resource.data.liveLocation.latitude is number)
              && (request.resource.data.liveLocation.longitude == null
                || request.resource.data.liveLocation.longitude is number)
              && (request.resource.data.liveLocation.lat == null
                || request.resource.data.liveLocation.lat is number)
              && (request.resource.data.liveLocation.lng == null
                || request.resource.data.liveLocation.lng is number)
              && (request.resource.data.liveLocation.accuracy == null
                || request.resource.data.liveLocation.accuracy is number)
            ))
      ) || (
          isSignedIn()
          && resource.data.uid is string
          && resource.data.uid == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "sessionActive",
            "sessionLastSeenAt",
            "liveLocation",
            "liveLocationUpdatedAt",
            "sessionStartedAt",
            "sessionEndedAt",
            "lastLoginAt",
            "status",
            "currentIncidentId",
            "updatedAt"
          ])
          && request.resource.data.updatedAt is timestamp
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["sessionActive"])
            || request.resource.data.sessionActive == null
            || request.resource.data.sessionActive is bool)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["sessionLastSeenAt"])
            || request.resource.data.sessionLastSeenAt == null
            || request.resource.data.sessionLastSeenAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["liveLocationUpdatedAt"])
            || request.resource.data.liveLocationUpdatedAt == null
            || request.resource.data.liveLocationUpdatedAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["sessionStartedAt"])
            || request.resource.data.sessionStartedAt == null
            || request.resource.data.sessionStartedAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["sessionEndedAt"])
            || request.resource.data.sessionEndedAt == null
            || request.resource.data.sessionEndedAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["lastLoginAt"])
            || request.resource.data.lastLoginAt == null
            || request.resource.data.lastLoginAt is timestamp)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["status"])
            || request.resource.data.status == null
            || request.resource.data.status in ["Available", "Deployed", "Off-Duty"])
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["currentIncidentId"])
            || request.resource.data.currentIncidentId == null
            || request.resource.data.currentIncidentId is string)
          && (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["liveLocation"])
            || request.resource.data.liveLocation == null
            || (
              (
                (request.resource.data.liveLocation.latitude is number
                  && request.resource.data.liveLocation.longitude is number)
                || (request.resource.data.liveLocation.lat is number
                  && request.resource.data.liveLocation.lng is number)
              )
              && (request.resource.data.liveLocation.latitude == null
                || request.resource.data.liveLocation.latitude is number)
              && (request.resource.data.liveLocation.longitude == null
                || request.resource.data.liveLocation.longitude is number)
              && (request.resource.data.liveLocation.lat == null
                || request.resource.data.liveLocation.lat is number)
              && (request.resource.data.liveLocation.lng == null
                || request.resource.data.liveLocation.lng is number)
              && (request.resource.data.liveLocation.accuracy == null
                || request.resource.data.liveLocation.accuracy is number)
            ))
      );

      allow delete: if isAdmin();
    }

    match /responderLiveLocations/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.liveLocation is map
        && (
          (request.resource.data.liveLocation.latitude is number
            && request.resource.data.liveLocation.longitude is number)
          || (request.resource.data.liveLocation.lat is number
            && request.resource.data.liveLocation.lng is number)
        )
        && (request.resource.data.liveLocation.latitude == null
          || request.resource.data.liveLocation.latitude is number)
        && (request.resource.data.liveLocation.longitude == null
          || request.resource.data.liveLocation.longitude is number)
        && (request.resource.data.liveLocation.lat == null
          || request.resource.data.liveLocation.lat is number)
        && (request.resource.data.liveLocation.lng == null
          || request.resource.data.liveLocation.lng is number)
        && (request.resource.data.liveLocation.accuracy == null
          || request.resource.data.liveLocation.accuracy is number)
        && request.resource.data.liveLocationUpdatedAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow read: if isAdmin() || isOwner(uid);

      allow update: if isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "liveLocation",
          "liveLocationUpdatedAt",
          "updatedAt"
        ])
        && request.resource.data.liveLocation is map
        && (
          (request.resource.data.liveLocation.latitude is number
            && request.resource.data.liveLocation.longitude is number)
          || (request.resource.data.liveLocation.lat is number
            && request.resource.data.liveLocation.lng is number)
        )
        && (request.resource.data.liveLocation.latitude == null
          || request.resource.data.liveLocation.latitude is number)
        && (request.resource.data.liveLocation.longitude == null
          || request.resource.data.liveLocation.longitude is number)
        && (request.resource.data.liveLocation.lat == null
          || request.resource.data.liveLocation.lat is number)
        && (request.resource.data.liveLocation.lng == null
          || request.resource.data.liveLocation.lng is number)
        && (request.resource.data.liveLocation.accuracy == null
          || request.resource.data.liveLocation.accuracy is number)
        && request.resource.data.liveLocationUpdatedAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow delete: if false;
    }

    match /incidents/{incidentId} {
      allow create: if (
          isSignedIn()
          && isApprovedResident(request.auth.uid)
          && request.resource.data.residentId == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.category is string
          && request.resource.data.description is string
          && request.resource.data.location is string
          && request.resource.data.barangay is string
          && request.resource.data.priority in ["Critical", "High", "Low"]
          && request.resource.data.status == "Pending"
          && request.resource.data.source in ["Web", "SMS", "Call", "Radio"]
          && request.resource.data.lat is number
          && request.resource.data.lng is number
          && request.resource.data.assignedResponders is list
          && request.resource.data.residentName is string
          && request.resource.data.residentEmail is string
          && (request.resource.data.photoUrl == null || request.resource.data.photoUrl is string)
          && request.resource.data.reportedAt is timestamp
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp
        ) || (
          isAdmin()
          && request.resource.data.title is string
          && request.resource.data.category is string
          && request.resource.data.description is string
          && request.resource.data.location is string
          && request.resource.data.barangay is string
          && request.resource.data.priority in ["Critical", "High", "Low"]
          && request.resource.data.status in ["Pending", "pending"]
          && request.resource.data.source in ["Web", "SMS", "Call", "Radio", "Offline"]
          && request.resource.data.lat is number
          && request.resource.data.lng is number
          && request.resource.data.assignedResponders is list
          && request.resource.data.residentId is string
          && request.resource.data.residentName is string
          && request.resource.data.residentEmail is string
          && (request.resource.data.photoUrl == null || request.resource.data.photoUrl is string)
          && request.resource.data.reportedAt is timestamp
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp
        );

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.residentId == request.auth.uid)
        || (isSignedIn() && request.auth.uid in resource.data.assignedResponders)
        || (
          isSignedIn()
          && resource.data.responderResponses is map
          && request.auth.uid in resource.data.responderResponses.keys()
        )
        || (
          isSignedIn()
          && request.auth.token.email is string
          && resource.data.assignedResponderEmails is list
          && request.auth.token.email in resource.data.assignedResponderEmails
        );

      allow update: if (
          isAdmin()
          && request.resource.data.residentId == resource.data.residentId
        ) || (
          // Responder lifecycle updates: allow assigned responder to change status safely
          // without failing on unrelated legacy fields.
          isSignedIn()
          && (
            request.auth.uid in resource.data.assignedResponders
            || (
              resource.data.responderResponses is map
              && request.auth.uid in resource.data.responderResponses.keys()
            )
            || (
              request.auth.token.email is string
              && resource.data.assignedResponderEmails is list
              && request.auth.token.email in resource.data.assignedResponderEmails
            )
          )
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "resolvedAt",
            "updatedAt",
            "responderResponses",
            "assignedResponders",
            "assignedResponderEmails"
          ])
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.status in ["pending", "assigned", "en_route", "on_scene", "resolved"]
          && (
            request.resource.data.status == "resolved"
            ? request.resource.data.resolvedAt is timestamp
            : request.resource.data.resolvedAt == null
              || request.resource.data.resolvedAt == resource.data.resolvedAt
          )
          && request.resource.data.assignedResponders is list
          && (request.resource.data.assignedResponderEmails == null
            || request.resource.data.assignedResponderEmails is list)
        ) || (
          isSignedIn()
          && (
            request.auth.uid in resource.data.assignedResponders
            || (
              resource.data.responderResponses is map
              && request.auth.uid in resource.data.responderResponses.keys()
            )
            || (
              request.auth.token.email is string
              && resource.data.assignedResponderEmails is list
              && request.auth.token.email in resource.data.assignedResponderEmails
            )
          )
          && request.resource.data.residentId == resource.data.residentId
          && request.resource.data.title == resource.data.title
          && request.resource.data.category == resource.data.category
          && request.resource.data.description == resource.data.description
          && request.resource.data.location == resource.data.location
          && request.resource.data.barangay == resource.data.barangay
          && request.resource.data.priority == resource.data.priority
          && request.resource.data.source == resource.data.source
          && request.resource.data.lat == resource.data.lat
          && request.resource.data.lng == resource.data.lng
          && request.resource.data.residentName == resource.data.residentName
          && request.resource.data.residentEmail == resource.data.residentEmail
          && request.resource.data.photoUrl == resource.data.photoUrl
          && request.resource.data.reportedAt == resource.data.reportedAt
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.status in ["pending", "assigned", "en_route", "on_scene", "resolved"]
          && (
            request.resource.data.status == "resolved"
            ? request.resource.data.resolvedAt is timestamp
            : request.resource.data.resolvedAt == null
              || request.resource.data.resolvedAt == resource.data.resolvedAt
          )
          && request.resource.data.assignedResponders is list
          && (request.resource.data.assignedResponderEmails == null
            || request.resource.data.assignedResponderEmails is list)
          && (
            request.resource.data.assignedResponders == resource.data.assignedResponders
            || (
              request.auth.uid in resource.data.assignedResponders
              && !(request.auth.uid in request.resource.data.assignedResponders)
              && request.resource.data.assignedResponders.size() == resource.data.assignedResponders.size() - 1
              && resource.data.assignedResponders.hasAll(request.resource.data.assignedResponders)
              && request.resource.data.status == "pending"
            )
            || (
              request.auth.uid in request.resource.data.assignedResponders
              && !(request.auth.uid in resource.data.assignedResponders)
              && request.resource.data.assignedResponders.size() == resource.data.assignedResponders.size() + 1
              && request.resource.data.assignedResponders.hasAll(resource.data.assignedResponders)
              && request.auth.token.email is string
              && resource.data.assignedResponderEmails is list
              && request.auth.token.email in resource.data.assignedResponderEmails
            )
          )
        );

      allow delete: if false;
    }

    match /sms_reports/{smsId} {
      allow read: if isAdmin();

      allow update: if isAdmin()
        && request.resource.data.sender == resource.data.sender
        && request.resource.data.message == resource.data.message;

      allow create: if false;
      allow delete: if false;
    }

    match /incoming_sms/{smsId} {
      allow read: if isAdmin();

      allow update: if isAdmin()
        && request.resource.data.sender == resource.data.sender
        && request.resource.data.message == resource.data.message;

      allow create: if false;
      allow delete: if false;
    }

    // Default deny for everything else unless explicitly opened later.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
